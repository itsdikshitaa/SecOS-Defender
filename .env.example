# =============================================================================
# SecOS Defender — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values before running in production.
# The server reads all SECOS_* variables automatically via pydantic-settings.
# =============================================================================

# ---- Server Database --------------------------------------------------------
# PostgreSQL connection string for the API server and worker.
# For local development, SQLite is used by default (no config needed).
SECOS_DATABASE_URL=postgresql+psycopg://secos:secos@localhost:5432/secos

# ---- API Authentication -----------------------------------------------------
# Shared secret required by all non-health API endpoints.
# Agents, the console, and the demo producer must all use the same value.
SECOS_API_KEY=change-this-to-a-strong-random-secret

# ---- CORS Allowed Origins ---------------------------------------------------
# Comma-separated list of origins allowed to make cross-origin requests.
SECOS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Console (Vite Build) ---------------------------------------------------
# Required by the React console at build time. Must match SECOS_API_KEY above.
VITE_API_KEY=change-this-to-a-strong-random-secret
# WebSocket base URL — defaults to window.location.origin, override if different.
VITE_WS_BASE_URL=ws://localhost:8000

# ---- Agent Configuration ----------------------------------------------------
# The Go agent reads SECOS_API_KEY to authenticate with the server.
SECOS_API_KEY=change-this-to-a-strong-random-secret
